# RSPS-RRI Orchestration — Environment Configuration Template
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ─── OpenRouter (Multi-model routing) ────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
# Free tier available — no card required
OPENROUTER_API_KEY=sk-or-your-key-here

# Alternate provider: Mistral AI (free tier) ------------------------------------------------
# When MISTRAL_API_KEY is set the orchestrator will prefer the Mistral
# endpoint over OpenRouter.  You can also override the model name below.
MISTRAL_API_KEY=sk-mistral-you-got-here
# Default Mistral model; change as newer versions appear
MISTRAL_MODEL=mistral-large

# ─── Model Configuration ──────────────────────────────────────────────────────
# Comma-separated list of 3 models for the Triangle Residue cycle
# Free tier options: claude-3-haiku, gpt-4o-mini, deepseek/deepseek-chat
# Recommended paid: claude-sonnet-4-6, gpt-4o, deepseek/deepseek-r1
DEFAULT_MODELS=claude-3-haiku-20240307,gpt-4o-mini,deepseek/deepseek-chat

# ─── Triangle Residue Test ────────────────────────────────────────────────────
# 1=Proxy (fast, cosine similarity), 2=Geometric (PCA parallel transport)
# Use 1 for production, 2 for analytical batch runs
TRIANGLE_RESIDUE_LEVEL=1

# ─── Server Configuration ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ─── ρ-Archive Persistence ────────────────────────────────────────────────────
# Path to the JSON-backed ρ-archive file
# Phase 3: replace with DATABASE_URL for SQLAlchemy
RHO_ARCHIVE_PATH=./rsps_rho_archive.json
OPERATIONAL_ARCHIVE_DEPTH=5000

# ─── IDS Configuration ────────────────────────────────────────────────────────
IDS_TARGET=0.65
FEEDBACK_GAIN=0.15
CAUSAL_SHEAR_DAMPING=0.30

# ─── n8n Integration ──────────────────────────────────────────────────────────
# URL where this FastAPI server is accessible from n8n
# For local development: http://host.docker.internal:8000 (if n8n runs in Docker)
N8N_CALLBACK_URL=http://localhost:8000
ORCHESTRATION_API_URL=http://localhost:8000

# ─── Android Device Integration ───────────────────────────────────────────────
# The Android app POSTs IDS scores and τ-anchor updates here
# For local dev with Android emulator: use 10.0.2.2:8000
# For physical device: use your machine's LAN IP
ANDROID_API_URL=http://10.0.2.2:8000

# ─── CMCP Configuration ───────────────────────────────────────────────────────
CMCP_PACKET_VERSION=1.0
# Default session TTL in seconds (4 hours = stale τ-lock threshold)
SESSION_TTL_SECONDS=14400

# ─── Development Flags ────────────────────────────────────────────────────────
# Set to true to return mock responses instead of calling OpenRouter
# Useful for testing pipeline logic without API key
USE_MOCK_RESPONSES=false
MOCK_RESPONSE_DELAY_MS=200
